# ==============================================================================
# SMS Gateway Platform - Monorepo Configuration Template
# Copy this file as `.env` in the respective application directories or define them
# in your execution shell.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. NestJS Backend API Configuration (apps/backend/.env)
# ------------------------------------------------------------------------------

# Port the backend server will listen on
PORT=3000

# MongoDB Connection URI
# Example: mongodb://username:password@localhost:27017/database?authSource=admin
MONGODB_URI=mongodb://localhost:27017/sms-gateway

# Redis Server Configuration (Backs BullMQ processing queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cryptographic Token Signing Secret (Highly recommended to change in production!)
# Use command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=super-secret-key-change-in-production

# Authentication tokens expiration interval
JWT_EXPIRES_IN=7d


# ------------------------------------------------------------------------------
# 2. React Admin Dashboard UI Configuration (apps/dashboard/.env)
# ------------------------------------------------------------------------------

# The HTTP API endpoint of the NestJS Backend.
# When built for production, the Vite compiler embeds this variable.
VITE_API_URL=http://localhost:3000


# ------------------------------------------------------------------------------
# 3. React Native Mobile Host App Configuration (apps/mobile/.env)
# ------------------------------------------------------------------------------

# API address to connect and issue registration requests.
# Note: For Android Emulator, localhost is accessible via `http://10.0.2.2:3000`
BACKEND_URL=http://10.0.2.2:3000

# Socket.io server connection url to receive SMS dispatch commands.
# Note: For Android Emulator, localhost is accessible via `http://10.0.2.2:3000`
GATEWAY_WS_URL=http://10.0.2.2:3000

# Hardcoded hardware identifier for debugging / offline dev testing.
DEVICE_ID=device_dev_1

# Default phone number configured on SIM 1 (E.164 format)
DEFAULT_PHONE_NUMBER=+919876543210

# Cellular carrier provider name
DEFAULT_PROVIDER=Jio

# Human-readable display label for this device
DEFAULT_NAME=Dev Simulator SIM1
